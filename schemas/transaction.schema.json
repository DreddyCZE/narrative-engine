{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/transaction.schema.json",
  "title": "Transaction Contract Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "schemaId", "schemaVersion", "baseRevision", "source", "effects"],
  "properties": {
    "contractVersion": {
      "type": "string",
      "const": "transaction@0.1.0"
    },
    "schemaId": {
      "type": "string",
      "const": "transaction"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "transactionId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*){2}$",
      "minLength": 3,
      "maxLength": 128
    },
    "baseRevision": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "source": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "command-plan"
            },
            "commandId": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*){2}$",
              "minLength": 3,
              "maxLength": 128
            },
            "commandType": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$",
              "minLength": 3,
              "maxLength": 128
            },
            "allowNoOp": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "systemId"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "system"
            },
            "systemId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "reason": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "allowNoOp": {
              "type": "boolean"
            }
          }
        }
      ]
    },
    "effects": {
      "type": "array",
      "minItems": 0,
      "maxItems": 32,
      "items": {
        "$ref": "./effect.schema.json"
      }
    },
    "context": {
      "$ref": "#/$defs/jsonValue"
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    }
  },
  "$defs": {
    "jsonValue": {
      "anyOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number", "minimum": -2147483647, "maximum": 2147483647 },
        { "type": "string", "maxLength": 1024 },
        {
          "type": "array",
          "maxItems": 64,
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" },
          "propertyNames": {
            "not": {
              "enum": ["__proto__", "prototype", "constructor"]
            }
          }
        }
      ]
    }
  }
}

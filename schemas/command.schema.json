{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/command.schema.json",
  "title": "Command Contract Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "schemaId",
    "schemaVersion",
    "commandType",
    "payload"
  ],
  "properties": {
    "contractVersion": {
      "const": "command@0.1.0"
    },
    "schemaId": {
      "const": "command"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "commandId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*){2}$"
    },
    "commandType": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$"
    },
    "expectedRevision": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "actor": {
      "$ref": "#/$defs/typedReference"
    },
    "initiator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["system", "ui", "editor", "network", "scheduler", "service"]
        },
        "sourceId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 0,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/typedReference"
      }
    },
    "preconditions": {
      "type": "array",
      "minItems": 0,
      "maxItems": 16,
      "items": {
        "$ref": "./condition.schema.json"
      }
    },
    "payload": {
      "$ref": "#/$defs/jsonValue"
    },
    "correlationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "causationId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    }
  },
  "anyOf": [
    {
      "required": ["actor"]
    },
    {
      "required": ["initiator"]
    }
  ],
  "$defs": {
    "typedReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "entityType"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 96,
          "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*){2}$"
        },
        "entityType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    },
    "jsonValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "integer",
          "minimum": -2147483647,
          "maximum": 2147483647
        },
        {
          "type": "number",
          "minimum": -2147483647,
          "maximum": 2147483647,
          "not": {
            "type": "integer"
          }
        },
        {
          "type": "string",
          "maxLength": 1024
        },
        {
          "type": "array",
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "maxProperties": 32,
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          },
          "propertyNames": {
            "type": "string",
            "not": {
              "enum": ["__proto__", "prototype", "constructor"]
            }
          }
        }
      ]
    }
  }
}
